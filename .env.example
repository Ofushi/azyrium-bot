# ── Discord ──────────────────────────────────────
BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# ── Role Reactions (plugin: role-reactions) ───────
# Format: MESSAGE_ID:EMOJI=ROLE_ID,EMOJI=ROLE_ID
ROLE_REACTION_MAP=123456789:⭐=111111111,🎮=222222222

# ── Tickets (plugin: tickets) ─────────────────────
TICKET_CATEGORY_ID=your_category_id
TICKET_SUPPORT_ROLE_ID=your_support_role_id
TICKET_LOG_CHANNEL_ID=your_log_channel_id

# ── /info command ─────────────────────────────────
INFO_LINKS=Rules=https://example.com/rules,Website=https://example.com,Discord=https://discord.gg/invite

# ── Minecraft (plugin: minecraft-status) ──────────
MINECRAFT_HOST=your.server.ip
MINECRAFT_PORT=25565
MINECRAFT_STATUS_CHANNEL_ID=your_channel_id

# ── Contestation (plugin: contestation) ───────────
CONTESTATION_LOG_CHANNEL_ID=your_log_channel_id
CONTESTATION_ADMIN_ROLE_ID=your_admin_role_id
